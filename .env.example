# Mise — environment configuration.
# Copy to `.env.local` and fill in your own values. Never commit real keys.

# OpenAI — recipe text + image generation
OPENAI_API_KEY=sk-...

# Supabase — database + auth.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service-role key: server-side only, NEVER prefixed with NEXT_PUBLIC_. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public client (used for sign-in / session). The anon key is designed to be
# public — set these to the SAME values as SUPABASE_URL / SUPABASE_ANON_KEY above.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
